#include <stdio.h>
#include <string.h>

int main() {
    char str[100];

    printf("Enter a line: ");
    fgets(str, sizeof(str), stdin);

    if (str[0] == '/' && str[1] == '/') {
        printf("Single Line Comment\n");
    }
    else if (str[0] == '/' && str[1] == '*') {
        int len = strlen(str);

        if (str[len - 3] == '*' && str[len - 2] == '/')
            printf("Multi Line Comment\n");
        else
            printf("Beginning of Multi Line Comment\n");
    }
    else {
        printf("Not a Comment\n");
    }

    return 0;
}
